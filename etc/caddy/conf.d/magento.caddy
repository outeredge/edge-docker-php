# #############################################################################
# Magento 2.4.8+ - for use with the base Caddyfile, served from `pub/`.
#
# Translates security rules from Magento's various .htaccess files plus the
# routing logic from the official nginx.conf.sample.
# #############################################################################

# -- Magento-specific 404s (don't confirm existence) --
@hidden_magento path_regexp magento_hidden (?i)/errors/.*\.xml$|/media/theme_customization/.*\.xml$|/cron\.php$|/RELEASE_NOTES\.txt$|/COPYING\.txt$|/LICENSE.*\.txt$
respond @hidden_magento 404

# -- Hard denies (403): private media + setup/update apps --
@blocked {
	path /media/customer/* /media/downloadable/* /media/import/* /media/custom_options/*
	path /setup* /update*
}
respond @blocked 403

# -- Block script execution inside /media/ and /static/ --
# Mirrors `php_flag engine 0` + `AddHandler cgi-script` denies in those .htaccess files.
@unsafe_exec path_regexp unsafe ^/(media|static)/.*\.(php|phtml|pl|py|jsp|asp|sh|cgi|htm|shtml)$
respond @unsafe_exec 403

# -- Block .phtml anywhere (Magento template files, never web-served) --
@phtml path *.phtml
respond @phtml 403

# -- Block TRACE / TRACK (XST mitigation from pub/.htaccess) --
@trace method TRACE TRACK
respond @trace 405

# -- /static/ handling --
#
# Two separate route{} blocks are required because both rewrites must fire on
# the same request in sequence:
#   1. Strip the cache-busting version prefix from the URI.
#   2. If the resulting unversioned file is absent on disk, hand off to
#      static.php so Magento can materialise it on demand.
#
# A single route{} block would put both rewrites in the same Caddy "group",
# making them mutually exclusive (first match wins). The version-strip would
# always win, the missing-file rewrite would never fire, and missing static
# URLs would fall through to index.php instead of static.php.

# Step 1: Strip cache-busting version prefix (/static/version1234/foo -> /static/foo).
# Matches with or without a version segment so the regex is idempotent on re-entry.
route {
	@static path_regexp static ^/static/(?:version\d+/)?(.*)$
	rewrite @static /static/{re.static.1}
}

# Step 2: If the unversioned file does not exist on disk, materialise via
# static.php. Resource path is the regex capture (everything after /static/),
# matching the canonical nginx.conf.sample behaviour.
route {
	@static_missing {
		path_regexp static_missing ^/static/(.*)$
		not file
	}
	rewrite @static_missing /static.php?resource={re.static_missing.1}

	# /media/ falls back to get.php for missing files.
	@media_missing {
		path /media/*
		not file
	}
	rewrite @media_missing /get.php
}

# -- Long-cache headers for static assets (only if APP_ENV is "prod") --
@is_prod expression `{env.APP_ENV} == "prod"`
header @is_prod /static/* Cache-Control "public, max-age=31536000, immutable"
header @is_prod /media/* Cache-Control "public, max-age=31536000"

# -- PHP entry-point whitelist --
# Only Magento's known entry points may be executed. Any other .php URL
# (uploads, leftover scripts, vendor files) returns 403.
@bad_php {
	path *.php
	not path /index.php /get.php /static.php /health_check.php /errors/*.php
}
respond @bad_php 403

# -- Terminal handler: serve static files, route everything else to index.php --
# php_server already handles /static.php and /get.php (rewritten above) plus
# the front-controller fallback to /index.php.
php_server {
	env HTTPS {http.request.header.HTTPS}
	env SERVER_PORT {http.request.header.X-Forwarded-Port}
}

# -- Custom error pages via Magento's error controller --
handle_errors {
	@magento_errors expression `{err.status_code} in [403, 404, 503]`
	rewrite @magento_errors /errors/{err.status_code}.php
	php_server {
		env HTTPS {http.request.header.HTTPS}
		env SERVER_PORT {http.request.header.X-Forwarded-Port}
	}
}
